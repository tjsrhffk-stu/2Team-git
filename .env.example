# ── 기본 ─────────────────────────────────────────────────
SECRET_KEY=여기에_안전한_시크릿키_입력
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
SITE_URL=https://your-domain.com

# ── 데이터베이스 ─────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=localeats
DB_USER=localeats_user
DB_PASSWORD=your_db_password
DB_HOST=192.168.1.177        # 프록시 VIP (write/read 공통)
DB_PORT=5432                 # default(write) 포트

# readonly DB: 별도 계정이 없으면 위 DB_USER/DB_PASSWORD가 자동으로 사용됨
DB_READONLY_PORT=5433        # readonly(read) 포트
# DB_READONLY_USER=localeats_readonly   # (선택) 읽기 전용 DB 계정
# DB_READONLY_PASSWORD=your_readonly_pw # (선택) 읽기 전용 DB 비밀번호

# ── 외부 API 키 ──────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
KAKAO_REST_API_KEY=your_kakao_api_key

# ── 이메일 ───────────────────────────────────────────────
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
